<%- include("head.partial.ejs") %>

<main>
  <a href="/">Powrót</a>
  <h1><%= title %></h1>

  <div>
    <strong>Sortuj według oceny:</strong>
    <a href="?sort=lowest">Od najgorszej |</a>
    <a href="?sort=highest">Od najlepszej |</a>
    <a href="/moje_polubione/<%= category.id %>">Resetuj</a>
  </div>

  <table>
    <thead>
      <tr>
        <% category.requiredFields.forEach(field => { %>
          <th>
            <%=
              field === "tytuł" ? "Tytuł" :
              field === "wykonawca" ? "Wykonawca" :
              field === "gatunek" ? "Gatunek" :
              field === "ocena" ? "Ocena" : field
            %>
          </th>
        <% }) %>
        <% if (locals.currentUser && locals.currentUser.isAdmin) { %>
          <th>Właściciel</th>
        <% } %>
        <th>Akcje</th>
      </tr>
    </thead>

    <tbody>
      <% category.cards.forEach(function(card, index){ %>
        <tr style="cursor:pointer;" onclick="openModalFromBtn(this)"
          data-tytul="<%= card.tytuł || '' %>"
          data-wykonawca="<%= card.wykonawca || '' %>"
          data-gatunek="<%= card.gatunek || '' %>"
          data-ocena="<%= card.ocena %>"
          data-spotify="<%= card.spotify_url || '' %>"
          data-cardid="<%= card.id %>"
          data-categoryid="<%= category.id %>"
        >
          <% category.requiredFields.forEach(field => { %>
            <td>
              <% const value = card[field] || '-'; %>
              <% if (card.spotify_url && field === (category.requiredFields.includes('tytuł') ? 'tytuł' : 'wykonawca')) { %>
                <a href="<%= card.spotify_url %>" target="_blank" rel="noopener" class="spotify-link" onclick="event.stopPropagation()">
                  <%= value %>
                  <img src="/img/spotify.svg" alt="Spotify">
                </a>
              <% } else { %>
                <%= value %>
              <% } %>
            </td>
          <% }) %>

          <% if (locals.currentUser && locals.currentUser.isAdmin) { %>
            <td><%= card.ownerName || '-' %></td>
          <% } %>

          <td style="white-space:nowrap;" onclick="event.stopPropagation()">
            <% if (locals.currentUser) { %>
              <form action="/moje_polubione/<%= category.id %>/edit/<%= card.id %>" method="GET" style="display:inline;">
                <button type="submit">Edytuj</button>
              </form>
              <form action="/moje_polubione/<%= category.id %>/delete/<%= index %>" method="POST" style="display:inline;">
                <button type="submit" class="delete" onclick="return confirm('Czy na pewno chcesz usunąć ten wpis?');">Usuń</button>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              </form>
            <% } else { %>
              -
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <% if (locals.currentUser) { %>
    <div>
      <h3>Nowe polubienie</h3>
      <%- include("forms/nowe_polubienie.ejs") %>
    </div>
  <% } else { %>
    <p><a href="/logowanie">Zaloguj się</a>, aby dodawać ulubione.</p>
  <% } %>
</main>

<%- include("foot.partial.ejs") %>