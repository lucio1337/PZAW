<form action="/moje_polubione/<%= category.id %>/new" method="POST">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <% category.requiredFields.forEach(function(field){ %>
    <div>
      <label for="card_<%= field %>"><%= field.charAt(0).toUpperCase() + field.slice(1) %></label>
      <% if (field === "ocena") { %>
        <input type="number" name="<%= field %>" id="card_<%= field %>" required min="1" max="10" step="0.1" value="<%= locals[field] || '' %>">
      <% } else { %>
        <input type="text" name="<%= field %>" id="card_<%= field %>" required minlength="1" maxlength="500" value="<%= locals[field] || '' %>">
      <% } %>
    </div>
  <% }) %>

  <div>
    <label for="spotify_url">
      <img src="/img/spotify.svg" alt="Spotify">
      Link Spotify (opcjonalnie)
    </label><br>
    <input
      type="url"
      name="spotify_url"
      id="spotify_url"
      value="<%= locals.spotify_url || '' %>"
    >
  </div>

  <button>Dodaj</button>
</form>