<a href="/">Powrót na główną</a>
<form action="/logowanie" method="POST">
  
  <div>
    
    <label for="username">Nazwa użytkownika</label>
    <input
      type="text"
      id="username"
      name="username"
      value="<%= username || '' %>"
    />
  </div>

  <div>
    <label for="password">Hasło</label>
    <input
      type="password"
      id="password"
      name="password"
    />
  </div>

  <button type="submit">Zaloguj</button>
</form>

