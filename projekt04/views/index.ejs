<%- include("head.partial.ejs") %>

<main>
  <h1><%= title %></h1>

  <% if (!locals.currentUser) { %>
    <p><a href="/logowanie">Zaloguj się</a>, aby dodawać i przeglądać swoje ulubione albumy, utwory, artystów i playlisty.</p>
  <% } %>

  <% if (top && ((top.albums && top.albums.length) || (top.artists && top.artists.length) || (top.songs && top.songs.length))) { %>
    <section class="card top-stats">
      <div class="card__header">
        <h2>Najczęściej dodawane do ulubionych</h2>
        <h3>TOP 5</h3>
      </div>

      <div class="top-stats__grid">
        <% if (top.albums && top.albums.length) { %>
          <div class="top-stats__panel">
            <h3>Albumy</h3>
            <ol class="top-stats__list">
              <% top.albums.forEach(item => { %>
                <li class="top-stats__item">
                  <span class="top-stats__name" title="<%= item.name %>"><%= item.name %></span>
                  <span class="top-stats__count"><%= item.count %></span>
                </li>
              <% }) %>
            </ol>
          </div>
        <% } %>

        <% if (top.artists && top.artists.length) { %>
          <div class="top-stats__panel">
            <h3>Artyści</h3>
            <ol class="top-stats__list">
              <% top.artists.forEach(item => { %>
                <li class="top-stats__item">
                  <span class="top-stats__name" title="<%= item.name %>"><%= item.name %></span>
                  <span class="top-stats__count"><%= item.count %></span>
                </li>
              <% }) %>
            </ol>
          </div>
        <% } %>

        <% if (top.songs && top.songs.length) { %>
          <div class="top-stats__panel">
            <h3>Utwory</h3>
            <ol class="top-stats__list">
              <% top.songs.forEach(item => { %>
                <li class="top-stats__item">
                  <span class="top-stats__name" title="<%= item.name %>"><%= item.name %></span>
                  <span class="top-stats__count"><%= item.count %></span>
                </li>
              <% }) %>
            </ol>
          </div>
        <% } %>
      </div>
    </section>
  <% } %>

  <% if (categories.length === 0) { %>
    <p>Nie masz jeszcze żadnych kategorii.</p>
  <% } else { %>
    <% if (locals.currentUser) { %>
    <details class="rolled-menu">
      <summary class="rolled-menu__summary">Menu zarządzania</summary>
      <div class="rolled-menu__content">
        <div class="rolled-menu__section">
          <div class="rolled-menu__title">Kategorie</div>
          <ul class="rolled-menu__list">
            <% categories.forEach(cat => { %>
              <li><a href="/moje_polubione/<%= cat.id %>"><%= cat.title %></a></li>
            <% }) %>
          </ul>
        </div>

        <div class="rolled-menu__section">
          <div class="rolled-menu__title">Playlisty</div>
          <ul class="rolled-menu__list">
            <li><a href="/playlista">Tworzenie nowej playlisty</a></li>
          </ul>
        </div>
      </div>
    </details>
    <% } %>
  <% } %>

  
  <% categories.forEach(category => { %>
    <% if (category.cards && category.cards.length > 0) { %>
      <% if (category.title=="ulubieni artyści") { %>
      <h2>Twoi <%= category.title %></h2>
      <% } else { %>
      <h2>Twoje <%= category.title %></h2>
      <% } %>

      <div class="sort-controls">
        <strong>Sortuj według oceny:</strong>
        <form action="/" method="GET" class="sort-controls__form">
          <input type="hidden" name="sort" value="lowest" />
          <input type="hidden" name="category" value="<%= category.id %>" />
          <button type="submit" class="btn btn--ghost">Od najgorszej</button>
        </form>
        <form action="/" method="GET" class="sort-controls__form">
          <input type="hidden" name="sort" value="highest" />
          <input type="hidden" name="category" value="<%= category.id %>" />
          <button type="submit" class="btn btn--ghost">Od najlepszej</button>
        </form>
        <form action="/" method="GET" class="sort-controls__form">
          <button type="submit" class="btn btn--ghost">Resetuj</button>
        </form>
      </div>

      <table>
        <thead>
          <tr>
            <% if (category.requiredFields.includes("tytuł")) { %>
              <th>Tytuł</th>
            <% } %>
            <% if (category.requiredFields.includes("wykonawca")) { %>
              <th>Wykonawca</th>
            <% } %>
            <% if (category.requiredFields.includes("gatunek")) { %>
              <th>Gatunek</th>
            <% } %>
            <% if (category.requiredFields.includes("ocena")) { %>
              <th>Ocena</th>
            <% } %>
            <% if (locals.currentUser && locals.currentUser.isAdmin) { %>
              <th>Właściciel</th>
            <% } %>

              <th>Szybka akcja</th>
          </tr>
        </thead>

        <tbody>
          <% category.cards.forEach(function(card, index){ %>
            <tr>
              <% if (card.tytuł) { %>
                <td><%= card.tytuł %></td>
              <% } %>
              <% if (card.wykonawca) { %>
                <td><%= card.wykonawca %></td>
              <% } %>
              <% if (card.gatunek) { %>
                <td><%= card.gatunek %></td>
              <% } %>
              <% if (card.ocena) { %>
                <td><%= card.ocena %></td>
              <% } %>
              <% if (locals.currentUser && locals.currentUser.isAdmin) { %>
                <td><%= card.ownerName || '-' %></td>
              <% } %>

              <td>
                <% if (locals.currentUser) { %>
                  <form action="/moje_polubione/<%= category.id %>/edit/<%= card.id %>" method="GET" style="display:inline;">
                    <button type="submit">Edytuj</button>
                  </form>
                  <form action="/moje_polubione/<%= category.id %>/delete/<%= index %>" method="POST">
                    <button type="submit" class="delete" onclick="return confirm('Czy na pewno chcesz usunąć ten wpis?');">
                      Usuń
                    </button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <br>
    <% } %>
  <% }) %>

  <% if (playlists && playlists.length > 0) { %>
    <h2>Playlisty</h2>
    <% playlists.forEach((playlist, plIdx) => { %>
      <h3><%= playlist.name %><% if (locals.currentUser && locals.currentUser.isAdmin && playlist.ownerName) { %> <span style="font-weight:normal;color:#a7a7a7;">(użytkownik: <%= playlist.ownerName %>)</span><% } %></h3>
      <% if (playlist.songs && playlist.songs.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th>Tytuł utworu</th>
              <th>Wykonawca</th>
              <th>Gatunek</th>
            </tr>
          </thead>
          <tbody>
            <% playlist.songs.forEach(song => { %>
              <tr>
                <td><%= song.tytuł %></td>
                <td><%= song.wykonawca %></td>
                <td><%= song.gatunek || "-" %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p>Brak utworów w tej playliście.</p>
      <% } %>
      <% if (locals.currentUser || locals.currentUser.isAdmin) { %>
  <form action="/playlista/edit/<%= plIdx %>" method="GET" style="margin-top:0.5em;">
    <button type="submit">Edytuj playlistę</button>
  </form>
  <form action="/playlista/delete/<%= plIdx %>" method="POST" style="margin-top:0.5em;">
    <button type="submit" class="delete" onclick="return confirm('Czy na pewno chcesz usunąć tę playlistę?');">Usuń playlistę</button>
  </form>
<% } %>
      <br>
    <% }) %>
  <% } %>
  
</main>

<%- include("foot.partial.ejs") %>
