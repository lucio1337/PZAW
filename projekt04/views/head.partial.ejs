<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Trackly - Strona do zarządzania ulubioną muzyką">
    <meta name="keywords" content="javascript, music">
    <meta name="author" content="Lukasz Furmann">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <nav>
        
        <% if (currentUser) { %>
          <span>Zalogowany jako <strong><%= currentUser.username %></strong><% if (currentUser.isAdmin) { %> <em>(Admin)</em><% } %></span>
          <form action="/logout" method="POST" style="display: inline;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit">Wyloguj</button>
          </form>
        <% } else { %>
          <a href="/logowanie">Logowanie</a> 
          <a href="/rejestracja">Rejestracja</a>
        <% } %>
      </nav>
    </header>
    <% if (locals.adminNotifications && adminNotifications.length > 0) { %>
  <div class="admin-notice">
    <button class="admin-notice__close" onclick="document.querySelector('.admin-notice').style.display='none'" title="Zamknij">✕</button>
    <strong>⚠️ Administrator wykonał następujące zmiany na Twoim koncie:</strong>
    <ul>
      <% adminNotifications.forEach(n => { %>
        <li>
          <strong><%= n.adminName %></strong> - <%= n.action %>
          <% if (n.details) { %> (<%= n.details %>)<% } %>
          <span class="admin-notice__date"><%= n.created_at %> UTC</span>
        </li>
      <% }) %>
    </ul>
  </div>
<% } %>